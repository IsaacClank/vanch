# Example environment configuration for composing.

ENVIRONMENT="test"

DB_CONTAINER_PORT=5432
DB_HOST_PORT=5432
DB_HOST_VOLUME="/var/lib/vanch-db"
DB_PGDATA="/var/lib/postgresql/data"
DB_POSTGRES_PASSWORD="postgres"
DB_POSTGRES_USER="postgres"

EVENT_STORE_BROKER_CONTAINER_PORT=6379
EVENT_STORE_BROKER_HOST_PORT=6379

API_CONTAINER_PORT=3000
API_DATABASE_URL="postgresql://postgres:postgres@db:5432/postgres"
API_HOST_PORT=3001